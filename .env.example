# 方式一：飞书开放平台应用（你当前需要）
FEISHU_APP_ID=cli_xxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
# 接收方类型：chat_id / open_id / user_id / union_id / email
FEISHU_RECEIVE_ID_TYPE=chat_id
# 接收方 ID（比如群 chat_id）
FEISHU_RECEIVE_ID=oc_xxxxxxxxxxxxx

# 方式二：Webhook 机器人（可选）
FEISHU_WEBHOOK_URL=
# 可选：仅当机器人开启签名校验时填写
FEISHU_SECRET=

# 方式三：飞书命令机器人（手机发 run:xxx 到飞书，电脑执行）
FEISHU_BOT_HOST=0.0.0.0
FEISHU_BOT_PORT=9000
# 飞书事件订阅中的 Verification Token（可选，但建议配置）
FEISHU_EVENT_VERIFICATION_TOKEN=
# 只允许这些 open_id 发命令，多个逗号分隔；留空表示不限制（不推荐）
FEISHU_ALLOWED_OPEN_IDS=
# 命令白名单前缀，多个逗号分隔
FEISHU_ALLOWED_COMMAND_PREFIXES=pwd,ls,git status,python3
# 命令执行目录
FEISHU_CMD_WORKDIR=/Users/apple/Documents/New project 2
# 命令超时秒数
FEISHU_CMD_TIMEOUT_SEC=15

# 聊天模型配置（chat: 前缀）
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_API_BASE=https://api.openai.com/v1/chat/completions

# 百炼（DashScope 兼容模式）
BAILIAN_API_KEY=
BAILIAN_MODEL=qwen-plus
BAILIAN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions

# 路由：openai / bailian / split
LLM_PROVIDER=openai
# 是否开启按任务类型优先分流（1 开启，0 关闭）
LLM_TASK_ROUTER=1
# 命中这些关键词优先走百炼（逗号分隔）
HEAVY_CHEAP_TASK_KEYWORDS=批量抓取,初步清洗,长文本切分,去重,摘要,分类,提取,改写,翻译
# 当 LLM_PROVIDER=split 时，百炼分流百分比（0-100）
LLM_SPLIT_BAILIAN_PERCENT=50
# 回复前面是否加 [via openai]/[via bailian] 标签（1 开启，0 关闭）
LLM_REPLY_PROVIDER_TAG=1
